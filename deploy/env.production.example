# Runtime
HOST=0.0.0.0
PORT=8080
SELF_URL=https://tank-arena.example.com
ALLOWED_CORS_ORIGIN=https://tank-arena.example.com
RUST_LOG=backend=info,tower_http=info

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/app_database

# Platform auth
MCTAI_AUTH_URL=https://auth.mctai.app
MCTAI_AUTH_APP_TOKEN=replace-with-app-token
MCTAI_AUTH_JWKS_URL=https://auth.mctai.app/.well-known/jwks.json
JWT_SECRET=replace-with-long-random-secret

# Object storage. Use these exact names; do not rename them to S3_*, AWS_*, TIGRIS_*, or STORAGE_* aliases.
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-access-key-id
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-secret-access-key
OBJECT_STORAGE_BUCKET=replace-with-bucket
OBJECT_STORAGE_PREFIX=app_alex_0d18_tank_arena_a383c3/
OBJECT_STORAGE_ENDPOINT=https://fly.storage.tigris.dev
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Platform email. Leave both empty to disable outbound email.
MCTAI_EMAIL_URL=
MCTAI_EMAIL_APP_TOKEN=
